<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>14.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsAsErrors />
    <AnalysisLevel>latest</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <!--
      IDE0005 (remove unused usings) only runs at build time when documentation
      generation is on; without this, csc emits an "EnableGenerateDocumentationFile"
      error. We don't ship XML doc files, so suppress CS1591 (missing XML doc).
    -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <RootNamespace>$(MSBuildProjectName)</RootNamespace>
    <AssemblyName>$(MSBuildProjectName)</AssemblyName>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
    <InvariantGlobalization>true</InvariantGlobalization>

    <!-- Point Six Labors license validation at the repo-root sixlabors.lic so
         every consumer project finds it; the targets glob is rooted at each
         project dir and won't walk up. No-op when EnableImageSharpDrawing3 is
         unset (the licensing targets aren't imported). -->
    <SixLaborsLicenseFile Condition="'$(SixLaborsLicenseFile)' == '' And Exists('$(MSBuildThisFileDirectory)sixlabors.lic')">$(MSBuildThisFileDirectory)sixlabors.lic</SixLaborsLicenseFile>

    <!-- When a Six Labors license is present, compile the ImageSharp.Drawing 3
         backend in by default so `aspire run` (and any local `dotnet build`)
         can pick TESSERA_PAINT_BACKEND=imagesharp without an extra
         /p:EnableImageSharpDrawing3=true flag. Without a license, the
         property stays unset and the default license-key-free build path
         (SixLabors.ImageSharp 3.1.12, no Drawing 3) is preserved. Set
         EnableImageSharpDrawing3=false explicitly on the command line to
         opt back out when the license is present. -->
    <EnableImageSharpDrawing3 Condition="'$(EnableImageSharpDrawing3)' == '' And '$(SixLaborsLicenseFile)' != ''">true</EnableImageSharpDrawing3>

    <!--
      Strict-on-purpose, but a handful of CA / RCS rules are noisy on
      engine-internal code (no localization, lots of framework-instantiated
      UI types, interface stubs with unused params). Suppress them globally
      and revisit at v1 hardening (M10).
    -->
    <NoWarn>$(NoWarn);CA1303;CA1304;CA1305;CA1812;CA1716;CA1031;CA1822;CA2007;CA1062</NoWarn>
    <NoWarn>$(NoWarn);RCS1163;RCS1124;RCS1118;RCS1158;RCS1192;RCS1238</NoWarn>
  </PropertyGroup>

  <!--
    Analyzers are shared across every project. PrivateAssets="all" prevents
    them from being treated as transitive package references.
  -->
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" PrivateAssets="all" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="all" />
  </ItemGroup>

  <!--
    Starling.Skia keeps its Sk* handle wrappers `internal` (only the interop
    seam should name native shapes). wp:M3-06i's SkiaGraphiteBackend lives in
    Starling.Paint and drives those handles, so it needs internals access.
    Declared here rather than in Starling.Skia.csproj because wp:M3-06i may not
    edit src/Starling.Skia/* — 06h owns that project. Scoped by project name so
    only the Starling.Skia assembly emits the attribute.
  -->
  <ItemGroup Condition="'$(MSBuildProjectName)' == 'Starling.Skia'">
    <InternalsVisibleTo Include="Starling.Paint" />
  </ItemGroup>
</Project>
