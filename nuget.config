<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="https://api.nuget.org/v3/index.json" value="https://api.nuget.org/v3/index.json" />
    <!-- TEMPORARY: SixLabors nightly feed. Only needed until the shared glyph
         cache (codymullins/shared-glyph-cache, ImageSharp.Drawing PR #398) ships
         as a stable ImageSharp.Drawing release on nuget.org. Remove this source,
         the mapping below, and revert the Drawing pin in Directory.Packages.props
         once that release is out. -->
    <add key="sixlabors-nightly" value="https://f.feedz.io/sixlabors/sixlabors/nuget/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="https://api.nuget.org/v3/index.json">
      <package pattern="*" />
    </packageSource>
    <!-- Route ONLY the Drawing package to the nightly feed. Fonts, ImageSharp,
         WebGPU, and PolygonClipper stay on nuget.org via the * pattern above
         (longest-prefix match sends the exact id here). -->
    <packageSource key="sixlabors-nightly">
      <package pattern="SixLabors.ImageSharp.Drawing" />
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>