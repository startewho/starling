<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- The GUI project is an Exe; ProjectReference still produces a
         consumable assembly for the test runner. -->
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="FluentAssertions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Starling.Gui.Avalonia\Starling.Gui.Avalonia.csproj" />
    <ProjectReference Include="..\..\src\Starling.Layout\Starling.Layout.csproj" />
    <ProjectReference Include="..\..\src\Starling.Css\Starling.Css.csproj" />
    <ProjectReference Include="..\..\src\Starling.Dom\Starling.Dom.csproj" />
    <ProjectReference Include="..\..\src\Starling.Html\Starling.Html.csproj" />
  </ItemGroup>
</Project>
