<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MSTest" />
    <PackageReference Include="AwesomeAssertions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Starling.Html\Starling.Html.csproj" />
    <ProjectReference Include="..\Starling.Spec.Common\Starling.Spec.Common.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="..\..\testdata\spec\html5lib-tests\tokenizer\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>testdata\spec\html5lib-tests\tokenizer\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Content>
    <Content Include="..\..\testdata\spec\html5lib-tests\tree-construction\**\*.dat">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>testdata\spec\html5lib-tests\tree-construction\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Content>
  </ItemGroup>
</Project>
