<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>
  <!-- Mirror Starling.Paint.csproj: when EnableImageSharpDrawing3=true the
       Paint assembly compiles in the ImageSharp.Drawing 3 backend and defines
       TESSERA_IMAGESHARP_DRAWING. The test project needs the same constant so
       #if-gated tests for the ImageSharp path compile in lockstep. -->
  <PropertyGroup Condition=" '$(EnableImageSharpDrawing3)' == 'true' ">
    <DefineConstants>$(DefineConstants);TESSERA_IMAGESHARP_DRAWING</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="FluentAssertions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Starling.Paint\Starling.Paint.csproj" />
    <ProjectReference Include="..\..\src\Starling.Html\Starling.Html.csproj" />
    <ProjectReference Include="..\..\src\Starling.Layout\Starling.Layout.csproj" />
    <ProjectReference Include="..\..\src\Starling.Css\Starling.Css.csproj" />
    <ProjectReference Include="..\..\src\Starling.Dom\Starling.Dom.csproj" />
  </ItemGroup>
</Project>
