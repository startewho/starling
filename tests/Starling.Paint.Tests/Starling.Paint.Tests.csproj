<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>
  <!-- ImageSharp.Drawing 3 is now the engine's sole paint backend
       (wp:M5-skia-removal). No conditional compilation symbols are needed —
       the test source includes the ImageSharp tests unconditionally. -->
  <ItemGroup>
    <PackageReference Include="MSTest" />
    <PackageReference Include="AwesomeAssertions" />
  </ItemGroup>
  <!-- Real-world SVG fixtures (McMaster icons + the masthead logo) copied to
       the test output so the managed SVG decoder tests can decode them. -->
  <ItemGroup>
    <Content Include="..\..\testdata\images\svg\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>testdata\images\svg\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Content>
  </ItemGroup>
  <!-- Vendored resvg test-suite SVG corpus (MIT, see testdata/spec/resvg/README.md):
       one decode test case per file in ResvgCorpusTests. -->
  <ItemGroup>
    <Content Include="..\..\testdata\spec\resvg\tests\**\*.svg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>testdata\spec\resvg\tests\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Starling.Paint\Starling.Paint.csproj" />
    <ProjectReference Include="..\..\src\Starling.Paint.NeutralStub\Starling.Paint.NeutralStub.csproj" />
    <ProjectReference Include="..\..\src\Starling.Html\Starling.Html.csproj" />
    <ProjectReference Include="..\..\src\Starling.Layout\Starling.Layout.csproj" />
    <ProjectReference Include="..\..\src\Starling.Css\Starling.Css.csproj" />
    <ProjectReference Include="..\..\src\Starling.Dom\Starling.Dom.csproj" />
    <ProjectReference Include="..\Starling.Spec.Common\Starling.Spec.Common.csproj" />
  </ItemGroup>
</Project>
