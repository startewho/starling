<div class="island-shell">
    <span class="pulse"></span>
    <span class="title">Blazor WASM Island</span>
    <span class="state">@_message</span>
    <button class="counter" @onclick="Increment">@_count</button>
</div>

@code {
    private int _count;
    private string _message = "Blazor counter ready";

    private void Increment()
    {
        _count++;
        _message = $"Clicked {_count} time{(_count == 1 ? "" : "s")}";
    }
}
