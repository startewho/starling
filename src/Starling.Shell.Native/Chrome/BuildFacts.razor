@namespace Starling.Shell.Native
@using Microsoft.AspNetCore.Components

@* SPDX-License-Identifier: Apache-2.0 *@

<div style="position:relative;width:196px;height:68px;color:@LabelColor;font-size:11px;line-height:14px">
    <div style="position:absolute;left:0;top:0;width:196px;color:@ValueColor;font-family:'Geist Mono','SFMono-Regular',Menlo,Consolas,monospace">native shell</div>

    <div style="position:absolute;left:0;top:20px;width:54px">commit</div>
    <div style="position:absolute;right:0;top:20px;width:130px;text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:@ValueColor;font-family:'Geist Mono','SFMono-Regular',Menlo,Consolas,monospace">@ValueOrFallback(Commit)</div>

    <div style="position:absolute;left:0;top:36px;width:54px">js</div>
    <div style="position:absolute;right:0;top:36px;width:130px;text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:@ValueColor;font-family:'Geist Mono','SFMono-Regular',Menlo,Consolas,monospace">@ValueOrFallback(JsEngine)</div>

    <div style="position:absolute;left:0;top:52px;width:54px">render</div>
    <div style="position:absolute;right:0;top:52px;width:130px;text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:@ValueColor;font-family:'Geist Mono','SFMono-Regular',Menlo,Consolas,monospace">@ValueOrFallback(RenderBackend)</div>
</div>

@code {
    [Parameter] public string? Commit { get; set; }
    [Parameter] public string? JsEngine { get; set; }
    [Parameter] public string? RenderBackend { get; set; }
    [Parameter] public string LabelColor { get; set; } = "#58565a";
    [Parameter] public string ValueColor { get; set; } = "#82807c";

    private static string ValueOrFallback(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;
}
