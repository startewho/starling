<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <!-- Engine.Tests exercises internal helpers like ExtractDisplayText. -->
    <InternalsVisibleTo Include="Tessera.Engine.Tests" />
  </ItemGroup>
  <ItemGroup>
    <!-- Pure-managed legacy single-byte / CJK encodings (Rule-0 clean).
         NU1510: .NET 10 ships an in-box copy of this assembly, but the
         encoding provider must still be registered explicitly at startup
         (see TesseraEngine static ctor). Suppress the prune warning. -->
    <PackageReference Include="System.Text.Encoding.CodePages" NoWarn="NU1510" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Tessera.Common\Tessera.Common.csproj" />
    <ProjectReference Include="..\Tessera.Url\Tessera.Url.csproj" />
    <ProjectReference Include="..\Tessera.Net\Tessera.Net.csproj" />
    <ProjectReference Include="..\Tessera.Html\Tessera.Html.csproj" />
    <ProjectReference Include="..\Tessera.Dom\Tessera.Dom.csproj" />
    <ProjectReference Include="..\Tessera.Css\Tessera.Css.csproj" />
    <ProjectReference Include="..\Tessera.Layout\Tessera.Layout.csproj" />
    <ProjectReference Include="..\Tessera.Paint\Tessera.Paint.csproj" />
    <ProjectReference Include="..\Tessera.Loop\Tessera.Loop.csproj" />
    <ProjectReference Include="..\Tessera.Bindings\Tessera.Bindings.csproj" />
    <ProjectReference Include="..\Tessera.Js\Tessera.Js.csproj" />
  </ItemGroup>
</Project>
