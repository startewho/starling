<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- Host app, not an engine module: it links ASP.NET Core + gRPC, which the
         engine never imports. Exempt from the managed-first engine allowlist
         the same way Starling.AppHost / Starling.Gui are. -->
    <IsPackable>false</IsPackable>
    <!-- Generated protobuf/gRPC sources carry an <auto-generated> header so the
         analyzers skip them, but the strict warnings-as-errors build is still
         picky about a couple of codes the generators emit. Keep the project's
         own code strict; only waive the generator-only warnings. -->
    <NoWarn>$(NoWarn);CS8981;CA1707;CA1062;CA1031;CA2227;CA1819</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.AspNetCore" />
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Grpc.Tools" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Starling.Telemetry.Daemon.Tests" />
  </ItemGroup>

  <!-- Vendored opentelemetry-proto (Apache-2.0, tag v1.3.2). GrpcServices=Server
       so the three collector services get server base classes; the signal/common
       protos generate message types only. ProtoRoot lets the cross-file imports
       (opentelemetry/proto/common/v1/common.proto, …) resolve. -->
  <ItemGroup>
    <Protobuf Include="Protos\**\*.proto" ProtoRoot="Protos" GrpcServices="Server" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Starling.Common\Starling.Common.csproj" />
    <ProjectReference Include="..\Starling.Telemetry\Starling.Telemetry.csproj" />
    <ProjectReference Include="..\Starling.Mcp\Starling.Mcp.csproj" />
  </ItemGroup>

</Project>
