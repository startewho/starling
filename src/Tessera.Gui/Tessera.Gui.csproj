<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Override Directory.Build.props's single-target net10.0; MAUI needs the
         per-platform TargetFrameworks shape. Mac Catalyst only at v1 — Windows
         and Android are deferred. -->
    <TargetFrameworks>net10.0-maccatalyst</TargetFrameworks>
    <TargetFramework></TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>Tessera.Gui</RootNamespace>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <ApplicationTitle>Tessera</ApplicationTitle>
    <ApplicationId>dev.tessera.gui</ApplicationId>
    <ApplicationDisplayVersion>0.1</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>

    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">15.0</SupportedOSPlatformVersion>

    <!-- MAUI scaffolding generates code that trips a handful of the strict
         analyzer rules inherited from Directory.Build.props. The engine
         projects keep TreatWarningsAsErrors; the GUI relaxes it so MAUI's
         own generators don't gate the build. -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!-- CA1859 (return concrete types for perf) defaults to error severity;
         MAUI's nested-builder idiom violates it in places we don't control. -->
    <NoWarn>$(NoWarn);CA1859</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" />
    <ProjectReference Include="..\Tessera.Engine\Tessera.Engine.csproj" />
    <ProjectReference Include="..\Tessera.Telemetry\Tessera.Telemetry.csproj" />
  </ItemGroup>

  <!--
    wp:M3-06i transitively pulls Tessera.Skia (via Tessera.Paint) into the GUI's
    reference closure. Tessera.Skia ships libtessera_skia.dylib as a native
    runtime asset; MAUI's Mac Catalyst bundler then tries to run
    `install_name_tool` over it and fails on the nested runtimes/<rid>/native/
    layout. Proper GUI+Skia native-lib registration is wp:M3-06k-gui-canvas's
    job — until then, drop the transitively-copied dylib from the GUI bundle's
    native-reference set so the build stays green. The engine paint path the GUI
    uses today is still ImageSharp (the default backend); the GUI does not yet
    drive the Skia backend.
  -->
  <Target Name="DropTransitiveSkiaNative"
          BeforeTargets="_ComputeDynamicLibrariesToReidentify">
    <ItemGroup>
      <_FileNativeReference Remove="@(_FileNativeReference)"
          Condition="'%(Filename)%(Extension)' == 'libtessera_skia.dylib'" />
      <_DynamicLibraryToReidentify Remove="@(_DynamicLibraryToReidentify)"
          Condition="'%(Filename)%(Extension)' == 'libtessera_skia.dylib'" />
    </ItemGroup>
  </Target>
</Project>
